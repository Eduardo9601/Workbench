WITH
PARAMS AS (
    SELECT
        TO_DATE(:DATA_INICIO, 'DD/MM/YYYY') AS DATA_INICIO,
        TO_DATE(:DATA_FIM, 'DD/MM/YYYY') AS DATA_FIM
    FROM DUAL
    
    /*SELECT
        TO_DATE('&DATA_INICIO', 'DD/MM/YYYY') AS DATA_INICIO,
        TO_DATE('&DATA_FIM', 'DD/MM/YYYY') AS DATA_FIM
    FROM DUAL*/
),

ORG_ULT AS (
    SELECT
        ORG.COD_CONTRATO,
        ORG.COD_EMP,
        ORG.EDICAO_EMP,
        ORG.DES_EMP,
        ORG.COD_ORGANOGRAMA,
        ORG.COD_UNIDADE,
        ORG.DES_UNIDADE,
        ORG.DATA_INI_ORG,
        ORG.DATA_FIM_ORG,
        ORG.COD_REDE,
        ORG.DES_REDE,
        ORG.COD_TIPO,
        ORG.DES_TIPO,
        ORG.EDICAO_ORG_3,
        ORG.NOME3,
        ORG.EDICAO_ORG_4,
        ORG.NOME4,
        ROW_NUMBER() OVER (
            PARTITION BY ORG.COD_CONTRATO
            ORDER BY NVL(ORG.DATA_FIM_ORG, DATE '2999-12-31') DESC,
                     ORG.DATA_INI_ORG DESC
        ) AS RN
    FROM VH_EST_ORG_CONTRATO_AVT ORG
    CROSS JOIN PARAMS P
    WHERE ORG.DATA_INI_ORG <= P.DATA_FIM
      AND ORG.COD_EMP = 8
),

FUNCAO_ULT AS (
    SELECT
        FN.COD_CONTRATO,
        FN.COD_FUNCAO,
        FN.DES_FUNCAO,
        FN.DATA_INI_CLH,
        FN.DATA_FIM_CLH,
        ROW_NUMBER() OVER (
            PARTITION BY FN.COD_CONTRATO
            ORDER BY NVL(FN.DATA_FIM_CLH, DATE '2999-12-31') DESC,
                     FN.DATA_INI_CLH DESC
        ) AS RN
    FROM VH_CARGO_CONTRATO_AVT FN
    CROSS JOIN PARAMS P
    WHERE FN.DATA_INI_CLH <= P.DATA_FIM
      AND FN.DES_FUNCAO LIKE '%APRENDIZ%'
),

BASE_APRENDIZ AS (
    SELECT DISTINCT
           CT.STATUS,
           CT.COD_CONTRATO,
           CT.DES_PESSOA,
           CT.DATA_NASCIMENTO,
           CT.DATA_ADMISSAO,
           CT.DATA_DEMISSAO,
           CT.COD_VINCULO_EMPREG,
           FN.COD_FUNCAO,
           FN.DES_FUNCAO,
           ORG.COD_EMP,
           ORG.EDICAO_EMP,
           ORG.DES_EMP,
           ORG.COD_ORGANOGRAMA,
           ORG.COD_UNIDADE,
           ORG.DES_UNIDADE,
           ORG.DATA_INI_ORG,
           ORG.DATA_FIM_ORG,
           CASE
             WHEN ORG.COD_TIPO IN (2, 3) THEN ORG.EDICAO_ORG_3
             ELSE ORG.COD_UNIDADE
           END AS COD_FILIAL,
           CASE
             WHEN ORG.COD_TIPO IN (2, 3) THEN ORG.NOME3
             ELSE ORG.DES_UNIDADE
           END AS DES_FILIAL,
           CASE
             WHEN ORG.COD_TIPO IN (2, 3) THEN ORG.EDICAO_ORG_4
             ELSE ORG.COD_UNIDADE
           END AS COD_DIVISAO,
           CASE
             WHEN ORG.COD_TIPO IN (2, 3) THEN ORG.NOME4
             ELSE ORG.DES_UNIDADE
           END AS DES_DIVISAO,
           ORG.COD_REDE,
           ORG.DES_REDE,
           ORG.COD_TIPO,
           ORG.DES_TIPO
      FROM V_DADOS_CONTRATO_AVT CT
      JOIN ORG_ULT ORG
        ON ORG.COD_CONTRATO = CT.COD_CONTRATO
       AND ORG.RN = 1
      JOIN FUNCAO_ULT FN
        ON FN.COD_CONTRATO = CT.COD_CONTRATO
       AND FN.RN = 1
     WHERE ORG.EDICAO_ORG_4 IS NOT NULL
),

CONTRATO_EXPERIENCIA AS (
    SELECT
        A.COD_CONTRATO,
        A.DATA_INICIO AS DATA_INI_EXP,
        A.DATA_FIM AS DATA_FIM_EXP,
        TO_NUMBER(TRUNC(A.DATA_FIM - A.DATA_INICIO) + 1) AS DIAS_CONTRATO,
        B.DATA_AVALIACAO,
        B.IND_AVALIACAO,
        C.NUM_DIAS,
        C.IND_AVALIACOES,
        D.NOME_TIPO_CONTRATO,
        D.DURACAO_CONTRATO,
        ROW_NUMBER() OVER (
            PARTITION BY A.COD_CONTRATO
            ORDER BY A.DATA_FIM DESC, A.DATA_INICIO DESC
        ) AS RN
    FROM RHFP0304 A
    LEFT JOIN RHFP0305 B
           ON B.COD_CONTRATO = A.COD_CONTRATO
          AND B.DATA_INICIO = A.DATA_INICIO
    JOIN RHFP0314 C
      ON A.COD_TP_CONTRATO = C.COD_TP_CONTRATO
    JOIN RHFP0116 D
      ON C.COD_TIPO_CONTRATO = D.COD_TIPO_CONTRATO
    CROSS JOIN PARAMS P
    WHERE P.DATA_FIM BETWEEN A.DATA_INICIO AND A.DATA_FIM
),

APRENDIZES_ATIVOS AS (
    SELECT
        B.COD_UNIDADE,
        B.DES_UNIDADE,
        B.COD_ORGANOGRAMA,
        B.COD_REDE,
        B.DES_REDE,
        B.COD_TIPO,
        B.DES_TIPO,
        1 AS COD_STATUS_REL,
        'ATIVO' AS STATUS_REL,
        B.COD_CONTRATO,
        B.DES_PESSOA,
        B.DATA_ADMISSAO,
        B.DATA_DEMISSAO,
        B.COD_VINCULO_EMPREG,
        CE.DATA_INI_EXP,
        CE.DATA_FIM_EXP,
        CE.DIAS_CONTRATO,
        CE.DATA_AVALIACAO,
        CE.IND_AVALIACAO,
        CE.NUM_DIAS,
        CE.IND_AVALIACOES,
        CE.NOME_TIPO_CONTRATO,
        CE.DURACAO_CONTRATO,
        ROW_NUMBER() OVER (
            PARTITION BY B.COD_UNIDADE
            ORDER BY B.DES_PESSOA, B.COD_CONTRATO
        ) AS RN_ATIVO
    FROM BASE_APRENDIZ B
    CROSS JOIN PARAMS P
    LEFT JOIN CONTRATO_EXPERIENCIA CE
           ON CE.COD_CONTRATO = B.COD_CONTRATO
          AND CE.RN = 1
    WHERE B.DATA_ADMISSAO <= P.DATA_FIM
      AND (B.DATA_DEMISSAO IS NULL OR B.DATA_DEMISSAO > P.DATA_FIM)
),

APRENDIZES_DEMITIDOS_PERIODO AS (
    SELECT
        B.COD_UNIDADE,
        B.DES_UNIDADE,
        B.COD_ORGANOGRAMA,
        B.COD_REDE,
        B.DES_REDE,
        B.COD_TIPO,
        B.DES_TIPO,
        2 AS COD_STATUS_REL,
        'DEMITIDO' AS STATUS_REL,
        B.COD_CONTRATO,
        B.DES_PESSOA,
        B.DATA_ADMISSAO,
        B.DATA_DEMISSAO,
        B.COD_VINCULO_EMPREG,
        ROW_NUMBER() OVER (
            PARTITION BY B.COD_UNIDADE
            ORDER BY B.DATA_DEMISSAO, B.DES_PESSOA, B.COD_CONTRATO
        ) AS RN_DEMITIDO
    FROM BASE_APRENDIZ B
    CROSS JOIN PARAMS P
    WHERE B.DATA_DEMISSAO BETWEEN P.DATA_INICIO AND P.DATA_FIM
),

QTD_ATIVOS AS (
    SELECT
        COD_ORGANOGRAMA,
        COD_UNIDADE,
        MAX(DES_UNIDADE) AS DES_UNIDADE,
        MAX(COD_REDE) AS COD_REDE,
        MAX(DES_REDE) AS DES_REDE,
        MAX(COD_TIPO) AS COD_TIPO,
        MAX(DES_TIPO) AS DES_TIPO,
        COUNT(*) AS QTD_ATIVOS
    FROM APRENDIZES_ATIVOS
    GROUP BY COD_ORGANOGRAMA, COD_UNIDADE
),

QTD_DEMITIDOS AS (
    SELECT
        COD_ORGANOGRAMA,
        COD_UNIDADE,
        MAX(DES_UNIDADE) AS DES_UNIDADE,
        MAX(COD_REDE) AS COD_REDE,
        MAX(DES_REDE) AS DES_REDE,
        MAX(COD_TIPO) AS COD_TIPO,
        MAX(DES_TIPO) AS DES_TIPO,
        COUNT(*) AS QTD_DEMITIDOS
    FROM APRENDIZES_DEMITIDOS_PERIODO
    GROUP BY COD_ORGANOGRAMA, COD_UNIDADE
),

UNIDADES_BASE AS (
    SELECT
        NVL(A.COD_ORGANOGRAMA, D.COD_ORGANOGRAMA) AS COD_ORGANOGRAMA,
        NVL(A.COD_UNIDADE, D.COD_UNIDADE) AS COD_UNIDADE,
        NVL(A.DES_UNIDADE, D.DES_UNIDADE) AS DES_UNIDADE,
        NVL(A.COD_REDE, D.COD_REDE) AS COD_REDE,
        NVL(A.DES_REDE, D.DES_REDE) AS DES_REDE,
        NVL(A.COD_TIPO, D.COD_TIPO) AS COD_TIPO,
        NVL(A.DES_TIPO, D.DES_TIPO) AS DES_TIPO,
        GREATEST(NVL(A.QTD_ATIVOS, 0), NVL(D.QTD_DEMITIDOS, 0)) AS QTD_LINHAS
    FROM QTD_ATIVOS A
    FULL OUTER JOIN QTD_DEMITIDOS D
      ON A.COD_UNIDADE = D.COD_UNIDADE
),

LINHAS_UNIDADE AS (
    SELECT
        U.COD_ORGANOGRAMA,
        U.COD_UNIDADE,
        U.DES_UNIDADE,
        U.COD_REDE,
        U.DES_REDE,
        U.COD_TIPO,
        U.DES_TIPO,
        LEVEL AS ORDEM_LINHA
    FROM UNIDADES_BASE U
    CONNECT BY LEVEL <= U.QTD_LINHAS
       AND PRIOR U.COD_UNIDADE = U.COD_UNIDADE
       AND PRIOR SYS_GUID() IS NOT NULL
)

SELECT
    L.COD_ORGANOGRAMA,
    L.COD_UNIDADE,
    L.DES_UNIDADE AS UNIDADE,
    L.COD_REDE,
    L.DES_REDE AS REDE,
    L.COD_TIPO,
    L.DES_TIPO AS TIPO,

    A.COD_STATUS_REL AS COD_STATUS_ATIVO,
    A.STATUS_REL     AS STATUS_ATIVO,

    D.COD_STATUS_REL AS COD_STATUS_DEMITIDO,
    D.STATUS_REL     AS STATUS_DEMITIDO,

    A.COD_CONTRATO || ' - ' || A.DES_PESSOA AS APRENDIZ_ATIVO,
    A.DATA_ADMISSAO AS DT_ADMISSAO_ATIVO,
    A.COD_VINCULO_EMPREG AS VINCULO_ATIVO,
    A.DATA_INI_EXP AS DT_INI_CONTRATO_EXP,
    A.DATA_FIM_EXP AS DT_FIM_CONTRATO_EXP,
    A.DIAS_CONTRATO,
    A.NOME_TIPO_CONTRATO,
    A.DURACAO_CONTRATO,

    D.COD_UNIDADE AS COD_UNIDADE_DEMITIDO,
    D.DES_UNIDADE AS UNIDADE_DEMITIDO,
    D.COD_REDE AS COD_REDE_DEMITIDO,
    D.DES_REDE AS REDE_DEMITIDO,
    D.COD_CONTRATO || ' - ' || D.DES_PESSOA AS APRENDIZ_DEMITIDO,
    D.DATA_ADMISSAO AS DT_ADMISSAO_DEMITIDO,
    D.DATA_DEMISSAO AS DT_DEMISSAO_DEMITIDO,
    D.COD_VINCULO_EMPREG AS VINCULO_DEMITIDO

FROM LINHAS_UNIDADE L
LEFT JOIN APRENDIZES_ATIVOS A
       ON A.COD_UNIDADE = L.COD_UNIDADE
      AND A.RN_ATIVO = L.ORDEM_LINHA
LEFT JOIN APRENDIZES_DEMITIDOS_PERIODO D
       ON D.COD_UNIDADE = L.COD_UNIDADE
      AND D.RN_DEMITIDO = L.ORDEM_LINHA

WHERE (L.COD_TIPO = :TIPO OR :TIPO = 0)
  AND (L.COD_UNIDADE = :UNIDADE OR :UNIDADE = 0)
  AND (L.COD_REDE = :REDE OR :REDE = 0)

ORDER BY    
    L.COD_UNIDADE,
    L.COD_ORGANOGRAMA,
    L.ORDEM_LINHA
