CREATE OR REPLACE VIEW SISLOGWEB.V_REGIAO_UNIDADES_AVT AS
SELECT COD_EMP,
       COD_GRUPO,
       COD_QUEBRA AS COD_REGIAO,
       CASE
           /*AQUI AS REGIŐES PADRĂO*/ --OBS: Sujeito a alteraçőes
           WHEN COD_QUEBRA = 8701 THEN
            'REGIĂO I'
           WHEN COD_QUEBRA = 8702 THEN
            'REGIĂO II'
           WHEN COD_QUEBRA = 8703 THEN
            'REGIĂO III'
           WHEN COD_QUEBRA = 8704 THEN
            'REGIĂO IV'
           WHEN COD_QUEBRA = 8705 THEN
            'REGIĂO V'
           WHEN COD_QUEBRA = 8706 THEN
            'REGIĂO VI'
           WHEN COD_QUEBRA = 8707 THEN
            'REGIĂO VII'
           WHEN COD_QUEBRA = 8708 THEN
            'REGIĂO VIII'
           WHEN COD_QUEBRA = 8709 THEN
            'REGIĂO IX'
           WHEN COD_QUEBRA = 8710 THEN
            'REGIĂO X'
           WHEN COD_QUEBRA = 8711 THEN
            'REGIĂO XI'
            /*aqui inicia as regiőes da PORMENOS*/ --OBS: Sujeito a alteraçőes
           WHEN COD_QUEBRA = 9301 THEN
            'REGIĂO PORMENOS I'
           WHEN COD_QUEBRA = 9302 THEN
            'REGIĂO PORMENOS II'
           WHEN COD_QUEBRA = 9303 THEN
            'REGIĂO PORMENOS III'
           WHEN COD_QUEBRA = 9304 THEN
            'REGIĂO PORMENOS IV'
           WHEN COD_QUEBRA = 9305 THEN
            'REGIĂO PORMENOS V'
           WHEN COD_QUEBRA = 9306 THEN
            'REGIĂO PORMENOS VI'
           WHEN COD_QUEBRA = 9307 THEN
            'REGIĂO PORMENOS VII'
           WHEN COD_QUEBRA = 9308 THEN
            'REGIĂO PORMENOS VIII'
           WHEN COD_QUEBRA = 9309 THEN
            'REGIĂO PORMENOS IX'
           /*AQUI FICA A REGIĂO DA FRANCO*/ --OBS: Sujeito a alteraçőes
           WHEN COD_QUEBRA = 941 THEN
            'REGIĂO FRANCO GIORGI'
           WHEN COD_QUEBRA = 8730 THEN
            'E-COMERCE'
           ELSE
            NULL
       END AS DES_REGIAO,
       COD_UNIDADE,
       UPPER(GRZ_UTIL.BUSCA_DES_UNIDADE(COD_UNIDADE)) DES_UNIDADE,
       CASE
           WHEN COD_NIVEL2 = 810 THEN
            10
           WHEN COD_NIVEL2 = 830 THEN
            30
           WHEN COD_NIVEL2 = 840 THEN
            40
           WHEN COD_NIVEL2 = 850 THEN
            50
           WHEN COD_NIVEL2 = 870 THEN
            70
           ELSE
            NULL
       END AS COD_REDE,
       COD_NIVEL3
FROM NL.GE_GRUPOS_UNIDADES
WHERE COD_GRUPO IN (910, 930, 940, 950, 970)
AND COD_NIVEL2 IN (810, 830, 840, 850, 870)
AND COD_QUEBRA NOT IN (9999)
--AND COD_UNIDADE = 140
ORDER BY COD_UNIDADE
;















